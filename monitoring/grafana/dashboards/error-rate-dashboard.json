{
  "dashboard": {
    "id": null,
    "uid": "aimp-errors",
    "title": "AIMP - Error Rate & Reliability",
    "tags": ["aimp", "errors", "reliability"],
    "timezone": "UTC",
    "schemaVersion": 36,
    "refresh": "15s",
    "time": { "from": "now-6h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "endpoint",
          "type": "query",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "query": "label_values(aimp_http_requests_total, endpoint)",
          "multi": true,
          "includeAll": true,
          "current": { "text": ["All"], "value": ["$__all"] }
        },
        {
          "name": "method",
          "type": "custom",
          "query": "GET,POST,PUT,DELETE,PATCH",
          "multi": true,
          "includeAll": true,
          "current": { "text": ["All"], "value": ["$__all"] }
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Overall Error Rate (5xx)",
        "type": "gauge",
        "targets": [
          {
            "expr": "sum(rate(aimp_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(aimp_http_requests_total[5m])) * 100",
            "legendFormat": "Error Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "orange", "value": 5 },
                { "color": "red", "value": 10 }
              ],
              "mode": "absolute"
            },
            "custom": {
              "neutral": 0
            }
          }
        },
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "4xx Rate (Client Errors)",
        "type": "gauge",
        "targets": [
          {
            "expr": "sum(rate(aimp_http_requests_total{status=~\"4..\"}[5m])) / sum(rate(aimp_http_requests_total[5m])) * 100",
            "legendFormat": "4xx Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 10 },
                { "color": "orange", "value": 25 },
                { "color": "red", "value": 50 }
              ]
            }
          }
        },
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 }
      },
      {
        "id": 3,
        "title": "Error Count by Type",
        "type": "stat",
        "targets": [
          {
            "expr": "sum by (error_type) (increase(aimp_errors_total[1h]))",
            "legendFormat": "{{error_type}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 50 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
      },
      {
        "id": 4,
        "title": "Availability (Success Rate %)",
        "type": "gauge",
        "targets": [
          {
            "expr": "(1 - (sum(rate(aimp_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(aimp_http_requests_total[5m])))) * 100",
            "legendFormat": "Availability %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 90,
            "max": 100,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 90 },
                { "color": "orange", "value": 99 },
                { "color": "green", "value": 99.9 }
              ]
            }
          }
        },
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 }
      },
      {
        "id": 5,
        "title": "Error Rate by Endpoint (5xx)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum by (endpoint) (rate(aimp_http_requests_total{status=~\"5..\"}[5m])) / ignoring(endpoint) group_left sum(rate(aimp_http_requests_total[5m])) * 100",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "fillOpacity": 10
            }
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "id": 6,
        "title": "Status Code Distribution",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum by (status) (increase(aimp_http_requests_total[1h]))",
            "legendFormat": "HTTP {{status}}"
          }
        ],
        "options": {
          "pieType": "donut",
          "legend": { "displayMode": "table", "placement": "right" }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": { "tooltip": false, "viz": false, "legend": false }
            }
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
      },
      {
        "id": 7,
        "title": "Top Error-Producing Endpoints",
        "type": "table",
        "targets": [
          {
            "expr": "topk(15, sum by (method, endpoint, status) (increase(aimp_http_requests_total{status=~\"5..\"}[1h])))",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "indexByName": { "endpoint": 0, "method": 1, "status": 2, "Value": 3 }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Value" },
              "properties": [
                { "id": "custom.displayMode", "value": "gradient-gauge" },
                { "id": "thresholds", "value": { "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 5 },
                  { "color": "red", "value": 20 }
                ]}}
              ]
            }
          ]
        },
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 }
      },
      {
        "id": 8,
        "title": "Error Trend (1h window)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(aimp_http_requests_total{status=~\"5..\"}[1h]))",
            "legendFormat": "5xx errors/h"
          },
          {
            "expr": "sum(rate(aimp_http_requests_total{status=~\"4..\"}[1h]))",
            "legendFormat": "4xx errors/h"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10,
              "spanNulls": false
            }
          }
        },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 }
      }
    ]
  }
}