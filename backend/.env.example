# =============================================================================
# AI Marketing Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in REAL values.
# DO NOT commit .env to git - it should be in .gitignore.
# In production (Railway), set these via Dashboard > Variables.
#
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# ------------------------------------------------------------------------------
# CRITICAL - Application will FAIL to start if these are missing or weak
# ------------------------------------------------------------------------------

# JWT signing key - must be >= 32 chars, NOT a default/placeholder value
# This signs ALL access and refresh tokens - if leaked, attackers can forge tokens
JWT_SECRET_KEY=GENERATE_A_REAL_SECRET_WITH_PYTHON_C_IMPORT_SECRETS_PRINT_SECRETS_TOKEN_HEX_32

# AES-256 encryption key for API credential storage - must be >= 32 chars
# This encrypts stored Facebook/Google/TikTok API keys in the database
SECRET_KEY=GENERATE_A_DIFFERENT_SECRET_WITH_PYTHON_C_IMPORT_SECRETS_PRINT_SECRETS_TOKEN_HEX_32

# ------------------------------------------------------------------------------
# Database - At least one of these must be set
# ------------------------------------------------------------------------------

# Option A: Full database URL (preferred, Railway auto-provides this)
# Format: mysql+aiomysql://user:password@host:port/database
# Railway sets this automatically for MySQL service
DATABASE_URL=

# Option B: Railway individual MySQL env vars (auto-provided by Railway)
# These are automatically injected when you provision a MySQL service
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=

# ------------------------------------------------------------------------------
# Redis / Cache - At least one of these must be set
# ------------------------------------------------------------------------------

# Option A: Full Redis URL (preferred)
# Format: redis://host:port/db
REDIS_URL=redis://localhost:6379/0

# Option B: Railway Redis env vars (auto-provided by Railway)
REDIS_PUBLIC_URL=
REDISPRIVATE_URL=

# ------------------------------------------------------------------------------
# Celery - Background task queue
# ------------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ------------------------------------------------------------------------------
# AI / OpenAI - Required for AI features
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-real-openai-key-here

# ------------------------------------------------------------------------------
# External API Keys - Required for social media integrations
# These are ENCRYPTED at rest using SECRET_KEY
# ------------------------------------------------------------------------------
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# GOOGLE_ADS_DEVELOPER_TOKEN=
# TIKTOK_APP_ID=
# TIKTOK_SECRET=

# ------------------------------------------------------------------------------
# Object Storage (REQUIRED for production - S3 or Cloudflare R2)
# Local storage is default for dev but BLOCKED in production/staging.
# ------------------------------------------------------------------------------

# Storage provider: "local" (dev only) | "s3" | "r2"
# Railway: Set to "r2" and configure R2_* vars below
STORAGE_PROVIDER=local

# --- S3-compatible (AWS S3, MinIO, etc.) ---
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=ai-marketing-media
S3_REGION=auto

# --- Cloudflare R2 ---
# Endpoint: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ai-marketing-media
R2_REGION=auto

# CDN public URL for media serving (e.g. https://cdn.yourdomain.com)
CDN_URL=

# Local storage path (dev only - ignored when STORAGE_PROVIDER != local)
MEDIA_STORAGE_PATH=./media_storage

# ------------------------------------------------------------------------------
# Application Settings (optional - have sensible defaults)
# ------------------------------------------------------------------------------
# ENVIRONMENT=production          # development | staging | production
# DEBUG=false                     # NEVER true in production
# LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
# APP_NAME="AI Marketing Platform"

# CORS origins (comma-separated, or use Railway defaults)
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ------------------------------------------------------------------------------
# Monitoring & Observability (optional)
# ------------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=aimp-backend
