{
  "dashboard": {
    "id": null,
    "uid": "aimp-api-performance",
    "title": "AI Marketing Platform - API Performance",
    "tags": ["aimp", "api", "performance"],
    "timezone": "utc",
    "schemaVersion": 39,
    "refresh": "5s",
    "time": {
      "from": "now-30m",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "environment",
          "type": "custom",
          "query": "production,staging,development",
          "current": {
            "text": "production",
            "value": "production"
          },
          "hide": 0,
          "includeAll": false
        },
        {
          "name": "service",
          "type": "custom",
          "query": "aimp-backend",
          "current": {
            "text": "aimp-backend",
            "value": "aimp-backend"
          },
          "hide": 2
        }
      ]
    },
    "annotations": {
      "list": []
    },
    "panels": [
      {
        "id": 1,
        "title": "RPS (Requests/sec)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "sum(rate(aimp_http_requests_total{job=\"$service\"}[1m]))",
            "legendFormat": "RPS"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        },
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        }
      },
      {
        "id": 2,
        "title": "P50 Latency",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(aimp_http_request_duration_seconds_bucket{job=\"$service\"}[5m])) by (le))",
            "legendFormat": "p50"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 3,
        "title": "P95 Latency",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(aimp_http_request_duration_seconds_bucket{job=\"$service\"}[5m])) by (le))",
            "legendFormat": "p95"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.5},
                {"color": "red", "value": 2.0}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "P99 Latency",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(aimp_http_request_duration_seconds_bucket{job=\"$service\"}[5m])) by (le))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1.0},
                {"color": "red", "value": 5.0}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "5xx Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "sum(rate(aimp_http_requests_total{job=\"$service\",status=~\"5..\"}[5m])) / sum(rate(aimp_http_requests_total{job=\"$service\"}[5m])) * 100",
            "legendFormat": "5xx %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "4xx Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "sum(rate(aimp_http_requests_total{job=\"$service\",status=~\"4..\"}[5m])) / sum(rate(aimp_http_requests_total{job=\"$service\"}[5m])) * 100",
            "legendFormat": "4xx %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 25}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Request Rate by Endpoint (Top 10)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "topk(10, sum by (endpoint) (rate(aimp_http_requests_total{job=\"$service\"}[5m])))",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 8,
        "title": "P95 Latency by Endpoint (Top 10)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "topk(10, histogram_quantile(0.95, rate(aimp_http_request_duration_seconds_bucket{job=\"$service\"}[5m])) by (endpoint))",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Request Duration Heatmap",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "sum(rate(aimp_http_request_duration_seconds_bucket{job=\"$service\"}[5m])) by (le)",
            "format": "heatmap",
            "legendFormat": "{{le}}"
          }
        ],
        "heatmap": {},
        "dataFormat": "tsbuckets",
        "yAxis": {
          "format": "s",
          "logBase": 10,
          "show": true
        },
        "tooltip": {
          "show": true,
          "showHistogram": true
        }
      },
      {
        "id": 10,
        "title": "Error Rate by Type",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "sum by (error_type) (rate(aimp_errors_total{job=\"$service\"}[5m]))",
            "legendFormat": "{{error_type}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 15
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Slowest Endpoints (p95)",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(aimp_http_request_duration_seconds_bucket{job=\"$service\"}[5m])) by (endpoint, le))",
            "format": "table",
            "instant": true,
            "legendFormat": ""
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "indexByName": {
                "endpoint": 0,
                "Value": 1
              }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Value"},
              "properties": [
                {
                  "id": "unit",
                  "value": "s"
                },
                {
                  "id": "displayName",
                  "value": "P95 Latency"
                },
                {
                  "id": "custom.thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      {"color": "green", "value": null},
                      {"color": "yellow", "value": 0.5},
                      {"color": "red", "value": 2.0}
                    ]
                  }
                }
              ]
            }
          ]
        }
      },
      {
        "id": 12,
        "title": "Rate Limited Requests",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "sum by (endpoint) (rate(aimp_rate_limit_hits_total{job=\"$service\"}[5m]))",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 15
            }
          }
        }
      },
      {
        "id": 13,
        "title": "AI Request Latency by Model",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 28},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(aimp_ai_request_duration_seconds_bucket{job=\"$service\"}[5m])) by (model, le))",
            "legendFormat": "{{model}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 14,
        "title": "Social API Latency by Platform",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 28},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(aimp_social_api_duration_seconds_bucket{job=\"$service\"}[5m])) by (platform, le))",
            "legendFormat": "{{platform}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 15,
        "title": "DB Connection Pool",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 34},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "aimp_db_connection_pool_size{job=\"$service\"}",
            "legendFormat": "{{state}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line",
              "stacking": {"mode": "normal"},
              "fillOpacity": 30
            }
          }
        }
      },
      {
        "id": 16,
        "title": "Request Method Distribution",
        "type": "piechart",
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 34},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "sum by (method) (rate(aimp_http_requests_total{job=\"$service\"}[5m]))",
            "legendFormat": "{{method}}"
          }
        ],
        "options": {
          "pieType": "pie",
          "legend": {"displayMode": "table", "placement": "right"}
        }
      },
      {
        "id": 17,
        "title": "Status Code Distribution (Last 5m)",
        "type": "bargauge",
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 34},
        "datasource": {"type": "prometheus", "uid": "${prometheus}"},
        "targets": [
          {
            "expr": "sum by (status) (increase(aimp_http_requests_total{job=\"$service\"}[5m]))",
            "legendFormat": "{{status}}"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          }
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null}
              ]
            }
          }
        }
      }
    ]
  }
}
