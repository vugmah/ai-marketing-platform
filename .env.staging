# AI Marketing Platform v2.0 - Staging Environment
# Do NOT use production credentials here

# === Database ===
DATABASE_URL=mysql+aiomysql://aimp_staging:staging_db_pass_2024@mysql:3306/aimp_staging
DB_HOST=mysql
DB_PORT=3306
DB_NAME=aimp_staging
DB_USER=aimp_staging
DB_PASSWORD=staging_db_pass_2024

# === Redis ===
REDIS_URL=redis://redis:6379/1
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1

# === JWT / Security ===
JWT_SECRET_KEY=staging_jwt_secret_change_in_production_2024
SECRET_KEY=staging_secret_key_change_in_production_2024
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Celery / Queue ===
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
CELERY_TASK_ALWAYS_EAGER=false

# === MinIO / S3 ===
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=staging_minio
S3_SECRET_KEY=staging_minio_secret
S3_BUCKET_NAME=aimp-staging
S3_REGION=us-east-1
MINIO_CONSOLE_PORT=9001

# === AI / LLM ===
OPENAI_API_KEY=${OPENAI_API_KEY:-sk-staging-placeholder}
OPENAI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# === WebSocket ===
WS_MESSAGE_QUEUE=redis

# === Feature Flags ===
ENABLE_AI_SAFETY=true
ENABLE_TENANT_GOVERNANCE=true
ENABLE_OBSERVABILITY=true
ENABLE_COMPLIANCE_LOGGING=true

# === Monitoring ===
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
LOG_LEVEL=INFO
